# --- Optional: PostgreSQL (when set, Prisma replaces data/store.json) ---
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/pipeline?schema=public

# --- Azure Blob for document bodies (optional) ---
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_DOCUMENTS_CONTAINER=pipeline-documents

# --- Azure Storage Queue for run jobs (optional; with USE_LOCAL_EXECUTOR=false) ---
# AZURE_STORAGE_QUEUE_NAME=pipeline-runs

# --- Execution: default runs pipelines inside Next.js (also avoids double-firing Azure Queue in dev) ---
# USE_LOCAL_EXECUTOR=false
# RUN_PIPELINE_ORCHESTRATION_URL=http://localhost:3000/api/internal/run-pipeline-sync
# DISABLE_IN_PROCESS_SCHEDULER=true
# AZURE_TIMER_SCHEDULE_ENABLED=true

# --- Internal worker → Next API (set for Azure Functions queue/timer) ---
# INTERNAL_API_SECRET=generate-a-long-random-string
# APP_BASE_URL=http://localhost:3000

# --- Operator API auth (set in production; send as Authorization: Bearer <token>) ---
# OPERATOR_API_TOKEN=generate-a-long-random-string

# --- Safety gate for experimental server-side JS eval node ---
# ALLOW_UNSAFE_JS_SCRIPT_EVAL=false
